# MY_GEMINI_API_KEY: Required for Gemini AI API calls.
MY_GEMINI_API_KEY="YOUR_API_KEY_HERE"

# SUPABASE_SERVICE_ROLE_KEY: Required for admin operations (like account deletion).
# DO NOT EXPOSE THIS IN CLIENT-SIDE CODE.
SUPABASE_SERVICE_ROLE_KEY="MY_SUPABASE_SERVICE_ROLE_KEY"

# VITE_SUPABASE_URL: Public URL for your Supabase project.
VITE_SUPABASE_URL="https://your-project.supabase.co"

# VITE_SUPABASE_ANON_KEY: Public anonymous key for Supabase.
VITE_SUPABASE_ANON_KEY="your-anon-key"

# APP_URL: Inject runtime endpoint URL for OAuth callbacks.
APP_URL="MY_APP_URL"
